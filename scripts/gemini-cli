#!/usr/bin/env bash
set -euo pipefail

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  # Puzzle Runner often starts agents from a non-interactive process where
  # nvm's Node is not on PATH yet.
  # shellcheck disable=SC1090
  . "$NVM_DIR/nvm.sh"
  nvm use --silent default >/dev/null 2>&1 || nvm use --silent node >/dev/null 2>&1 || true
fi

node_major="$(node -p 'process.versions.node.split(".")[0]' 2>/dev/null || echo 0)"
if [[ "$node_major" =~ ^[0-9]+$ ]] && (( node_major >= 20 )) && command -v gemini >/dev/null 2>&1; then
  exec gemini "$@"
fi

for node_dir in "$NVM_DIR"/versions/node/v*; do
  candidate_major="$("$node_dir/bin/node" -p 'process.versions.node.split(".")[0]' 2>/dev/null || echo 0)"
  if [[ "$candidate_major" =~ ^[0-9]+$ ]] && (( candidate_major >= 20 )) && [[ -x "$node_dir/bin/gemini" ]]; then
    exec "$node_dir/bin/gemini" "$@"
  fi
done

exec gemini "$@"
